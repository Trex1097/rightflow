generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ARTIST
  LABEL
  ADMIN_BMDA
  RIGHTFLOW_ADMIN
}

enum RightType {
  DROIT_AUTEUR
  DROIT_VOISIN
  BOTH
}

enum SourceType {
  STREAMING
  RADIO
  ESPACE_PUBLIC
  SYNCHRONISATION
}

enum DetectionStatus {
  PENDING
  MATCHED
  UNMATCHED
}

enum PaymentCycleStatus {
  ACTIVE
  COMPLETED
  UPCOMING
}

enum PaymentStatus {
  SCHEDULED
  PROCESSING
  PAID
  FAILED
}

enum ReserveStatus {
  WAITING
  NOTIFIED
  CLAIMED
  REDISTRIBUTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          UserRole  @default(ARTIST)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  artist        Artist?
  label         Label?
}

model Artist {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  stageName     String
  bio           String?
  country       String    @default("MA")
  walletAddress String?
  iban          String?
  mobileMoneyNumber String?
  createdAt     DateTime  @default(now())
  works         Work[]    @relation("ArtistWorks")
  composedWorks Work[]    @relation("ComposerWorks")
  payments      Payment[]
}

model Label {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  name          String
  country       String    @default("MA")
  works         Work[]
  payments      Payment[]
  createdAt     DateTime  @default(now())
}

model Work {
  id            String    @id @default(cuid())
  title         String
  isrc          String    @unique
  iswc          String?
  rightType     RightType @default(BOTH)
  territories   String[]  @default(["MA"])
  isActive      Boolean   @default(true)
  artistId      String?
  artist        Artist?   @relation("ArtistWorks", fields: [artistId], references: [id])
  composerId    String?
  composer      Artist?   @relation("ComposerWorks", fields: [composerId], references: [id])
  labelId       String?
  label         Label?    @relation(fields: [labelId], references: [id])
  blockchainHash String?
  smartContractAddress String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  splits        Split[]
  detections    Detection[]
  rights        Right[]
  reserveFunds  ReserveFund[]
}

model Split {
  id            String    @id @default(cuid())
  workId        String
  work          Work      @relation(fields: [workId], references: [id])
  recipientType String    // "artist", "composer", "label", "publisher", "platform"
  recipientId   String?
  recipientName String
  percentage    Float
  rightType     RightType
  createdAt     DateTime  @default(now())
}

model Source {
  id            String    @id @default(cuid())
  name          String
  type          SourceType
  country       String    @default("MA")
  city          String?
  streamUrl     String?
  isActive      Boolean   @default(true)
  lastSeen      DateTime?
  deviceId      String?   // for IoT boxes
  createdAt     DateTime  @default(now())
  detections    Detection[]
}

model Detection {
  id            String          @id @default(cuid())
  workId        String?
  work          Work?           @relation(fields: [workId], references: [id])
  sourceId      String
  source        Source          @relation(fields: [sourceId], references: [id])
  detectedAt    DateTime        @default(now())
  duration      Int?            // seconds
  confidence    Float?
  status        DetectionStatus @default(PENDING)
  rawTitle      String?         // unmatched title
  rawArtist     String?         // unmatched artist
  rightType     RightType?
  rights        Right[]
}

model Right {
  id            String    @id @default(cuid())
  workId        String
  work          Work      @relation(fields: [workId], references: [id])
  detectionId   String?
  detection     Detection? @relation(fields: [detectionId], references: [id])
  sourceType    SourceType
  rightType     RightType
  amount        Float     // in MAD
  currency      String    @default("MAD")
  period        DateTime
  calculatedAt  DateTime  @default(now())
  payments      Payment[]
}

model PaymentCycle {
  id            String             @id @default(cuid())
  name          String             // "Q3 2025"
  startDate     DateTime
  endDate       DateTime
  paymentDate   DateTime
  status        PaymentCycleStatus @default(UPCOMING)
  totalAmount   Float              @default(0)
  createdAt     DateTime           @default(now())
  payments      Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  cycleId       String
  cycle         PaymentCycle  @relation(fields: [cycleId], references: [id])
  artistId      String?
  artist        Artist?       @relation(fields: [artistId], references: [id])
  labelId       String?
  label         Label?        @relation(fields: [labelId], references: [id])
  rightId       String?
  right         Right?        @relation(fields: [rightId], references: [id])
  amountDA      Float         @default(0) // droits auteur
  amountDV      Float         @default(0) // droits voisins
  totalAmount   Float
  currency      String        @default("MAD")
  status        PaymentStatus @default(SCHEDULED)
  paidAt        DateTime?
  method        String?       // "bank", "orange_money", "cih"
  reference     String?
  createdAt     DateTime      @default(now())
}

model ReserveFund {
  id            String        @id @default(cuid())
  workId        String
  work          Work          @relation(fields: [workId], references: [id])
  unregisteredName String     // name as detected
  amount        Float
  currency      String        @default("MAD")
  passageCount  Int           @default(0)
  sourceTypes   SourceType[]
  rightType     RightType
  status        ReserveStatus @default(WAITING)
  notifiedAt    DateTime?
  claimedAt     DateTime?
  redistributedAt DateTime?
  expiresAt     DateTime      // +18 months from first detection
  createdAt     DateTime      @default(now())
}
